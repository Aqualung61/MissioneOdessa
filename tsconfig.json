{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
  "outDir": "dist",
  // Permettiamo a TS Server di includere anche i test senza errori TS6059
  // (la build vera usa tsconfig.build.json che esclude i test).
  "rootDir": ".",
  "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "types/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
