# Esempio variabili d'ambiente

# Nota (Railway / hosting): non inserire virgolette nei valori.
# Esempio corretto: API_AUTH_DISABLED=1  (non API_AUTH_DISABLED="1")

# Porta del server
PORT=3001

# Base path (se servito sotto sottocartella, es. /odessa)
BASE_PATH=

# API key per proteggere /api/* (consigliato per deploy pubblico)
API_KEY=

# Disabilita l'autenticazione API key (utile se il sito è pubblico anonimo:
# una API key nel browser non è un segreto). Valori: 1/true/yes
API_AUTH_DISABLED=0

# Limite massimo body JSON (protezione DoS). Esempi: 256kb, 1mb, 2mb
JSON_BODY_LIMIT=1mb

# Se dietro reverse proxy/load balancer, abilita per usare l'IP reale del client
TRUST_PROXY=0

# Disabilita rate limiting (solo per troubleshooting/load test)
RATE_LIMIT_DISABLED=0

# Disabilita l'endpoint operativo /api/run-tests (consigliato in produzione pubblica).
# Valori: 1/true/yes
DISABLE_RUN_TESTS=0

# Disabilita endpoint legacy (consigliato per deploy pubblico / cleanup).
# - POST /api/engine/set-location
# - POST /api/parser/parse
# Valori: 1/true/yes
DISABLE_LEGACY_ENDPOINTS=0

# CORS (M3): se web app e API sono sullo stesso dominio, lascia vuoto.
# Se serve cross-origin (es. frontend su dominio diverso), imposta una whitelist CSV.
# Esempio: ALLOWED_ORIGINS=https://odessa.example.com,https://www.odessa.example.com
ALLOWED_ORIGINS=

# Limite massimo di turni che consumano tempo (esclude comandi SYSTEM).
# Se non impostato (variabile assente), il limite è DISABILITATO.
# Valore consigliato: 250.
GAME_MAX_TURNS_CONSUMED=250

# Debug engine (solo dev/test): aggiunge trace di debug sugli endpoint /api/engine/*
# (es. /api/engine/state, /api/engine/reset, /api/engine/execute) per ricostruire delta punteggio/trigger/game over.
# Il payload di debug include tipicamente i campi: enabled, maxEvents, size, events.
# Valori: 1/true/yes
ENGINE_DEBUG=0

# Sprint #59.1: sessioni in-memory (multi-session per-tab)
# Limita il numero massimo di sessioni tenute in memoria (default: 200)
SESSION_MAX_SESSIONS=200

# TTL idle (ms) dopo l'ultimo accesso: oltre questo valore la sessione viene rimossa (default: 6h)
SESSION_IDLE_TTL_MS=21600000

# TTL assoluto (ms) dalla creazione: oltre questo valore la sessione viene rimossa (default: 24h)
SESSION_ABSOLUTE_TTL_MS=86400000
